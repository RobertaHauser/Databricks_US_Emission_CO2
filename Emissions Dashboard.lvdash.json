{
  "datasets": [
    {
      "name": "0136f228",
      "displayName": "Location Data",
      "queryLines": [
        "select latitude,longitude,`GHG emissions mtons CO2e` as Emissions from emissions.default.emissions_data"
      ]
    },
    {
      "name": "22536117",
      "displayName": "Emissions per Person",
      "queryLines": [
        "SELECT county_state_name,population,\r\n",
        "    CAST(REPLACE(`GHG emissions mtons CO2e`, ',', '') AS DOUBLE) / NULLIF(CAST(REPLACE(population, ',', '') AS DOUBLE), 0) AS Emissions_per_person\r\n",
        "FROM emissions_data\r\n",
        "ORDER BY Emissions_per_person DESC;"
      ],
      "catalog": "emissions",
      "schema": "default"
    },
    {
      "name": "ad2eefc7",
      "displayName": "Total Emissions Per State",
      "queryLines": [
        "SELECT state_abbr,\r\n",
        "    SUM(CAST(REPLACE(`GHG emissions mtons CO2e`, ',', '') AS DOUBLE)) AS Total_Emissions\r\n",
        "    FROM emissions_data\r\n",
        "    GROUP BY state_abbr\r\n",
        "ORDER BY total_emissions DESC\r\n",
        "limit 10;"
      ],
      "catalog": "emissions",
      "schema": "default"
    },
    {
      "name": "89892407",
      "displayName": "Most Emissions",
      "queryLines": [
        "SELECT county_state_name,population,\r\n",
        "    CAST(REPLACE(`GHG emissions mtons CO2e`, ',', '') \r\n",
        "    AS DOUBLE) AS Total_emissions\r\n",
        "FROM emissions_data\r\n",
        "ORDER BY total_emissions DESC\r\n",
        "limit 10;"
      ],
      "catalog": "emissions",
      "schema": "default"
    }
  ],
